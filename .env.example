DATABASE_URL=postgresql://user:password@localhost:5432/skripsi_backend
MQTT_BROKER=localhost
MQTT_PORT=8883
MQTT_TOPIC=device/data
MQTT_CA_CERT=/etc/mosquitto/certs/ca.crt

# Comma-separated browser origins allowed to call the API.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Required for write endpoints such as PUT /api/v1/calibrations/{sensor}.
API_KEY=change-me

# Set 0 to disable the simple per-IP limiter.
RATE_LIMIT_PER_MINUTE=120
